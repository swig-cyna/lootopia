{
  "compilerOptions": {
    "noEmit": true,
    "noErrorTruncation": true,
    "esModuleInterop": true,
    "paths": {
      "@lootopia/mobile/*": ["./packages/mobile/src/*"],
      "@lootopia/dashboard/*": ["./packages/dashboard/src/*"],
      "@lootopia/api/*": ["./packages/api/src/*"],
      "@lootopia/db": ["./packages/db/src/index"],
      "@lootopia/db/*": ["./packages/db/src/*"],
      "@lootopia/auth/*": ["./packages/auth/src/*"],
      "@lootopia/common/*": ["./packages/common/src/*"]
    },
    "strict": true,
    "strictNullChecks": true
  }
}
