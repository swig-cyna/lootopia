{
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "noErrorTruncation": true,
    "esModuleInterop": true,
    "paths": {
      "@lootopia/dashboard": ["./packages/dashboard/src/*"],
      "@lootopia/api/*": ["./packages/api/src/*"],
      "@lootopia/db": ["./packages/db/src/index"],
      "@lootopia/db/*": ["./packages/db/src/*"],
      "@lootopia/auth": ["./packages/auth/src/index"],
      "@lootopia/auth/*": ["./packages/auth/src/*"],
      "@lootopia/eslint-config/*": ["./packages/eslint-config/*"]
    },
    "strict": true,
    "strictNullChecks": true
  }
}
