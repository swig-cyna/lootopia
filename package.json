{
  "name": "lootopia",
  "scripts": {
    "dev": "dotenv -e .env -- pnpm -r --parallel dev",
    "dev:web": "dotenv -e .env -- pnpm --filter web dev",
    "dev:api": "dotenv -e .env -- pnpm --filter api dev",
    "dev:dashboard": "dotenv -e .env -- pnpm --filter dashboard dev",
    "dev:mobile": "dotenv -e .env -- pnpm --filter mobile dev",
    "build": "dotenv -e .env -- pnpm -r run build",
    "start": "dotenv -e .env -- pnpm -r --parallel run start",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "lint": "pnpm -r --parallel --reporter=append-only run lint",
    "lint:fix": "pnpm -r --parallel --reporter=append-only run lint:fix",
    "format": "pnpm -r --parallel --reporter=append-only run format",
    "format:fix": "pnpm -r --parallel --reporter=append-only run format:fix",
    "kysely": "dotenv -e .env -- pnpm --filter db kysely",
    "prod:up": "docker compose -f compose.prod.yml up --build -d",
    "prod:down": "docker compose -f compose.prod.yml down"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3"
  }
}
