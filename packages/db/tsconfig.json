{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "types": ["node"],
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "migrations:all": ["./src/migrations.d.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
