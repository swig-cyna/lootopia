{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "types": ["node"],
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "migrations:all": ["./src/migrations.d.ts"],
      "@lootopia/common/*": ["../common/src/*"]
    }
  },
  "include": ["src", "kysely.config.ts"],
  "exclude": ["node_modules"]
}
